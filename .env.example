APP_NAME="EMPACAR S.A. - Sistema Comercial"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/La_Paz
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB_CONNECTION=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=db_estetica
# DB_USERNAME=postgres
# DB_PASSWORD=1234

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="EMPACAR S.A. - Sistema Comercial"


# Credenciales de PagoFácil
# tcTokenService
PAGOFACIL_COMMERCE_ID=""
PAGOFACIL_SERVICE_TOKEN=""

# tcTokenSecret
PAGOFACIL_SECRET_TOKEN=""

# Secreto interno para validar callbacks/webhooks. Debe enviarse en el header X-PagoFacil-Webhook-Secret
PAGOFACIL_WEBHOOK_SECRET=""

PAGOFACIL_BASE_URL="https://masterqr.pagofacil.com.bo/api/services/v2"

# auto: consulta /list-enabled-services y usa el paymentMethodId habilitado.
# También puedes colocar un número fijo si PagoFácil te informa uno concreto, por ejemplo 34.
PAGOFACIL_PAYMENT_METHOD=auto
PAGOFACIL_CACHE_SEGUNDOS=600

# Monto enviado al QR solo para prototipo académico.
# El sistema conserva internamente el monto real de la venta/cuota.
PAGOFACIL_MONTO_PRUEBA=0.01
URL_CALLBACK="http://127.0.0.1:8000/pagofacil/callback"

